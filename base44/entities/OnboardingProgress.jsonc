{
  "name": "OnboardingProgress",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "steps_completed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dismissed": {
      "type": "boolean",
      "default": false
    },
    "completed": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_email"
  ]
}